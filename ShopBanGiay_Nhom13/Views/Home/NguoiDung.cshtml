@model IEnumerable<ShopBanGiay_Nhom13.Models.KHACHHANG>

@{
    ViewBag.Title = "Người dùng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<h2 class="text-white mb-4">Danh sách người dùng</h2>

<table class="table table-dark table-bordered text-center align-middle">
    <thead>
        <tr>
            <th>Mã KH</th>
            <th>Tên khách hàng</th>
            <th>Số điện thoại</th>
            <th>Email</th>
            <th>Mật khẩu</th>
            <th>Quyền</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.MAKH</td>
                <td>@user.TENKH</td>
                <td>@user.SODIENTHOAI</td>
                <td>@user.EMAIL</td>
                <td>@user.PASSWORD_KH</td>
                <td>@user.ROLES</td>
            </tr>
        }
    </tbody>
</table>