@{
    ViewBag.Title = "GioHang";
    Layout = "~/Views/Shared/_LayoutKhachHang.cshtml";
}
@model List<ShopBanGiay_Nhom13.Models.GIOHANG>

<h2 class="text-white my-5">Giỏ hàng của bạn</h2>

@if (!Model.Any())
{
    <p class="text-white">Bạn chưa có sản phẩm nào trong giỏ hàng.</p>
}
else
{
    <table class="table table-bordered text-white">
        <thead>
            <tr>
                <th>Sản phẩm</th>
                <th>Giá</th>
                <th>Số lượng</th>
                <th>Tổng</th>
                <th>Thao tác</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.SANPHAM.TENSP</td>
                    <td>@String.Format("{0:N0} VNĐ", item.SANPHAM.GIA)</td>

                    <td>
                        <form action="@Url.Action("Update", "Cart")" method="post" style="display:flex;">
                            <input type="hidden" name="MaSP" value="@item.MASP" />
                            <input type="number" name="SoLuong" value="@item.SOLUONG" min="1" class="form-control" style="width:80px" />
                            <button type="submit" class="btn btn-success">Cập nhật</button>
                        </form>
                    </td>

                    <td>
                        @String.Format("{0:N0} VNĐ", item.SANPHAM.GIA * item.SOLUONG)
                    </td>

                    <td>
                        <a href="@Url.Action("Remove", "Cart", new { masp = item.MASP })"
                           class="btn btn-danger">
                            Xóa
                        </a>
                    </td>
                </tr>
            }
        </tbody>

        <tfoot>
            <tr>
                <th colspan="3">Tổng tiền:</th>
                <th>
                    @String.Format("{0:N0} VNĐ",
                        Model.Sum(x => x.SANPHAM.GIA* x.SOLUONG))
                </th>
                <th></th>
            </tr>
        </tfoot>
        
    </table>
    <div class="text-white">
        Thanh toán ngay:
        <a href="@Url.Action("ThanhToan", "Order")" class="btn btn-primary">
            Thanh toán
        </a>
    </div>
}

