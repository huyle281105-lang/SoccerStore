@{
    ViewBag.Title = "ThanhToan";
    Layout = "~/Views/Shared/_LayoutKhachHang.cshtml";
}

@model IEnumerable<ShopBanGiay_Nhom13.Models.GIOHANG>

@{
    ViewBag.Title = "Thanh toán";
    Layout = "~/Views/Shared/_LayoutKhachHang.cshtml";

    var kh = (Session["KHACHHANG"] ?? Session["KHACHHANGs"]) as ShopBanGiay_Nhom13.Models.KHACHHANG;
    decimal total = 0m;
    if (Model != null)
    {
        foreach (var it in Model)
        {
            var price = it.SANPHAM.GIA ?? 0m;
            var qty = it.SOLUONG ?? 0;
            total += price * qty;
        }
    }
    // Prefer controller to set ViewBag.Total; fallback to computed value
    if (ViewBag.Total == null)
    {
        ViewBag.Total = total;
    }
}

<h2 class="text-white my-5">Thanh toán</h2>

@if (kh == null)
{
    <div class="alert alert-warning">Bạn chưa đăng nhập. Vui lòng <a href="@Url.Action("SignIn", "Auth")">đăng nhập</a> để tiếp tục.</div>
}
else if (Model == null || !Model.Any())
{
    <div class="alert alert-info">Giỏ hàng trống. <a href="@Url.Action("Index", "Home")">Tiếp tục mua sắm</a></div>
}
else
{
    using (Html.BeginForm("LuuHoaDon", "Order", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <div class="row bg-white p-4">
            <!-- Cột trái -->
            <div class="col-md-6">
                <h4>Thông tin giao hàng</h4>
                <div class="form-group">
                    <label>Người nhận</label>
                    <input type="text" name="TenNguoiNhan" class="form-control" value="@kh.TENKH" required />
                </div>

                <div class="form-group">
                    <label>Số điện thoại</label>
                    <input type="text" name="SDT" class="form-control" value="@kh.SODIENTHOAI" required />
                </div>

                <div class="form-group">
                    <label>Địa chỉ</label>
                    <input type="text" name="DiaChi" class="form-control" placeholder="Số nhà, đường, phường, quận, tỉnh" required />
                </div>

                <div class="form-group">
                    <label>Ngày hẹn giao</label>
                    <input type="date" name="NgayHenGiao" class="form-control"
                           value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                </div>

                <h4>Phương thức thanh toán</h4>
                <div>
                    <label>
                        <input type="radio" name="ThanhToan" value="COD" checked /> Thanh toán khi nhận hàng (COD)
                    </label><br />
                </div>

                <div class="form-group mt-2">
                    <label>Ghi chú</label>
                    <textarea name="GhiChu" class="form-control" rows="3" placeholder="Ghi chú cho người giao hàng (không bắt buộc)"></textarea>
                </div>
            </div>

            <!-- Cột phải -->
            <div class="col-md-6">
                <h4>Đơn hàng</h4>
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-center">SL</th>
                            <th class="text-right">Đơn giá</th>
                            <th class="text-right">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var sp = item.SANPHAM;
                            var name = sp.TENSP ?? item.MASP;
                            var price = sp.GIA ?? 0m;
                            var qty = item.SOLUONG ?? 0;
                            var line = price * qty;

                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(sp.HINHANH))
                                    {
                                        <img src="@Url.Content("~/Content/Images/" + sp.HINHANH)" style="height:48px;margin-right:8px;" />
                                    }
                                    <strong>@name</strong>
                                </td>
                                <td class="text-center">@qty</td>
                                <td class="text-right">@price.ToString("N0") ₫</td>
                                <td class="text-right">@line.ToString("N0") ₫</td>

                                @* Hidden để gửi lên controller *@
                                <input type="hidden" name="Items.Index" value="@item.MASP" />
                                <input type="hidden" name="Items[@item.MASP].MASP" value="@item.MASP" />
                                <input type="hidden" name="Items[@item.MASP].SOLUONG" value="@qty" />
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <th colspan="3" class="text-right">Tạm tính</th>
                            <th id="TamTinh" class="text-right">@Model.Sum(x => (x.SANPHAM.GIA ?? 0) * (x.SOLUONG ?? 0)).ToString("N0") ₫</th>
                        </tr>
                        <tr>
                            <th colspan="3" class="text-right">Phí vận chuyển</th>
                            <th class="text-right">Miễn phí</th>
                        </tr>
                        <tr>
                            <th colspan="3" class="text-right">Tổng cộng</th>
                            <th id="TongCong" class="text-right">@Model.Sum(x => (x.SANPHAM.GIA ?? 0) * (x.SOLUONG ?? 0)).ToString("N0") ₫</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <div class="text-right mt-3">
            <button type="submit" class="btn btn-primary">Đặt hàng và thanh toán</button>
            <a href="@Url.Action("Index", "Cart")" class="btn btn-secondary">Quay lại Giỏ hàng</a>
        </div>
    }
}