@{
    ViewBag.Title = "SignUp";
    Layout = "~/Views/Shared/_LayoutKhachHang.cshtml";
}

<div class="container d-flex justify-content-center align-content-center">
    <form action="/Auth/SignUp" method="post" class="form-signup bg-success p-5 rounded-4" style="width: 400px;">
        <h3 class="text-white text-center my-2 mb-5">Đăng ký tài khoản</h3>
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center my-2" style="font-size: 14px; background-color: #f8d7da; color: #721c24; border-radius: 4px; padding: 8px;">
                @ViewBag.Error
            </div>
        }
        <div class="mb-2 mt-4">
            <input class="form-control w-100 d-inline-block" type="text" name="txtEmail" placeholder="Email" required/>
        </div>

        <div class="mb-2 mt-4">
            <input class="form-control w-100 d-inline-block" type="text" name="txtPhone" placeholder="Phone number" required/>
        </div>

        <div class="mb-2 mt-4">
            <input class="form-control w-100 d-inline-block" type="password" name="txtPass" placeholder="Password" required/>
        </div>

        <div class="mb-2 mt-4">
            <input class="form-control w-100 d-inline-block" type="password" name="txtRepass" placeholder="Confirm password" required/>
        </div>

        <div class="text-center my-4">
            <input class="btn btn-primary w-100" type="submit" value="Đăng ký" />
        </div>

        <div class="my-3 text-center ">
            <span class="text-white frm-label">Already a member? </span><a class="a-link" href="/Auth/SignIn">Sign in</a>
        </div>
    </form>
</div>

<style>
    .container {
    }

        .container .form-signup {
            border-radius: 30px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            min-height: 77vh;
            width: 50vh !important;
        }

    .frm-label {
        font-size: 16px;
    }

    .a-link {
        color: #fcd34d;
        font-size: 0.9rem;
        transition: 0.3s;
    }

        .a-link:hover {
            color: #a5f3fc;
            text-decoration: underline;
        }
</style>
