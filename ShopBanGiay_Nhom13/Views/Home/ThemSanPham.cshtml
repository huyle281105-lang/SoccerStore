@{
    ViewBag.Title = "Thêm sản phẩm";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container mt-4">

    <h2 class="text-white mb-4">Thêm sản phẩm mới</h2>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <form method="post" enctype="multipart/form-data">

        <!-- Mã sản phẩm -->
        <div class="form-group mb-3">
            <label class="text-light">Mã sản phẩm *</label>
            <input type="text" class="form-control" name="MASP" placeholder="VD: SP001, GIAY05..." required />
        </div>

        <!-- Tên sản phẩm -->
        <div class="form-group mb-3">
            <label class="text-light">Tên sản phẩm *</label>
            <input type="text" class="form-control" name="TENSP" required />
        </div>

        <!-- Hình ảnh -->
        <div class="form-group mb-3">
            <label class="text-light">Hình ảnh *</label>
            <input type="file" class="form-control" name="upload" required />
        </div>

        <!-- Số lượng -->
        <div class="form-group mb-3">
            <label class="text-light">Số lượng *</label>
            <input type="number" class="form-control" name="SOLUONG" min="1" required />
        </div>

        <!-- Giá -->
        <div class="form-group mb-3">
            <label class="text-light">Giá (₫) *</label>
            <input type="number" class="form-control" name="GIA" min="1" required />
        </div>

        <!-- Mô tả -->
        <div class="form-group mb-3">
            <label class="text-light">Mô tả</label>
            <textarea class="form-control" name="MOTA" rows="4"></textarea>
        </div>

        <!-- Loại sản phẩm -->
        <div class="form-group mb-3">
            <label class="text-light">Loại sản phẩm *</label>
            <select class="form-control" name="MAL" required>
                <option value="">-- Chọn loại --</option>
                @foreach (var item in ViewBag.Loai)
                {
                    <option value="@item.MAL">@item.TENL</option>
                }
            </select>
        </div>

        <!-- Thương hiệu -->
        <div class="form-group mb-3">
            <label class="text-light">Thương hiệu *</label>
            <select class="form-control" name="MATH" required>
                <option value="">-- Chọn thương hiệu --</option>
                @foreach (var item in ViewBag.ThuongHieu)
                {
                    <option value="@item.MATH">@item.TENTH</option>
                }
            </select>
        </div>

        <!-- Khuyến mãi -->
        <div class="form-group mb-3">
            <label class="text-light">Mã khuyến mãi (tuỳ chọn)</label>
            <select class="form-control" name="MAKM">
                <option value="">Không áp dụng</option>
                @foreach (var item in ViewBag.KhuyenMai)
                {
                    <option value="@item.MAKM">@item.TENKM</option>
                }
            </select>
        </div>

        <!-- Buttons -->
        <button type="submit" class="btn btn-success">
            ✔ Thêm sản phẩm
        </button>

        <a href="/Home/Dashboard" class="btn btn-secondary ms-2">
            ↩ Quay lại
        </a>

    </form>

</div>