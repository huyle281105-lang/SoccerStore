<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>SoccerStoreAdmin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="~/Content/bootstrap-5.0.2-dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body, input, select, textarea, button {
            font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background-color: #121212;
            color: #f1f1f1;
        }

        .sidebar {
            height: 100vh;
            width: 250px;
            background: #1e1e1e;
            position: fixed;
            top: 0;
            left: 0;
            padding: 20px;
        }

            .sidebar h3 {
                color: #00b894;
                font-weight: 700;
                margin-bottom: 30px;
                text-align: center;
            }

            .sidebar a {
                display: block;
                padding: 12px 15px;
                color: #bbb;
                text-decoration: none;
                border-radius: 6px;
                margin-bottom: 5px;
                transition: 0.3s;
            }

                .sidebar a:hover,
                .sidebar a.active {
                    background: #00b894;
                    color: #fff;
                }

        .main-content {
            margin-left: 250px;
            padding: 25px;
            background-color: #181818;
            min-height: 100vh;
        }

        .navbar-dark {
            background-color: #212121;
            border-bottom: 1px solid #333;
        }

        .card {
            background-color: #1f1f1f;
            border: none;
            border-radius: 12px;
            color: #eee;
        }

        .card-header {
            background-color: #272727;
            border-bottom: 1px solid #333;
            font-weight: 600;
        }

        footer {
            background-color: #1e1e1e;
            text-align: center;
            padding: 15px;
            color: #777;
            font-size: 0.9em;
        }

        .brand-logo {
            font-size: 1.4rem;
            font-weight: 700;
            color: #00b894;
            text-decoration: none;
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <h3>⚽ SOCCERSTORE  ADMIN</h3>
        <a href="@Url.Action("Dashboard", "Home")" >🏠 Dashboard</a>
        <a href="@Url.Action("ThemSanPham", "Home")">👟 Thêm Sản Phẩm</a>
        <a href="@Url.Action("HoaDon", "Home")">🧾 Orders</a>
        <a href="@Url.Action("NguoiDung", "Home")">👤 Người Dùng</a>
        <a href="@Url.Action("Logout", "Auth")">🚪 Logout</a>
    </div>

    <div class="main-content">
        <nav class="navbar navbar-dark">
            <div class="container-fluid">
                <a class="brand-logo" href="@Url.Action("Index", "Dashboard")">SoccerStore Admin</a>
            </div>
        </nav>

        <div class="container-fluid mt-4">
            @RenderBody()
        </div>

        <footer>
            © @DateTime.Now.Year SoccerStore Admin Panel
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>